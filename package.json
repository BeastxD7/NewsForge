{
  "name": "news-app",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "dev:web": "bun run --filter './apps/web' dev",
    "dev:server": "bun run --filter './apps/server' dev",
    "build": "bun run --filter '*' build",
    "start": "bun run --filter './apps/*' start",
    "start:web": "bun run --filter './apps/web' start",
    "start:server": "bun run --filter './apps/server' start",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "db:generate": "bun run --filter './packages/db' db:generate",
    "db:migrate": "bun run --filter './packages/db' db:migrate",
    "db:push": "bun run --filter './packages/db' db:push",
    "db:studio": "bun run --filter './packages/db' db:studio",
    "db:seed": "bun run --filter './packages/db' db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test": "bun test tests/",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:watch": "bun test --watch tests/unit"
  },
  "overrides": {
    "ioredis": "5.10.0"
  }
}
