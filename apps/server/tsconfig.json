{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@news-app/db": ["../../packages/db/src/index.ts"],
      "@news-app/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src", "../../packages/db/src", "../../packages/types/src"],
  "exclude": ["node_modules"]
}
