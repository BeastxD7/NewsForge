# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://news:news@localhost:5432/newsapp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-byte-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Express Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Shared secret for Next.js → Express auth verification
API_SECRET=your-api-secret-here

# ── AI providers — set the key for whichever provider you activate ────────────
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# Groq  (https://console.groq.com)
GROQ_API_KEY=

# OpenRouter  (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Azure OpenAI  (set endpoint via admin dashboard AI config → baseUrl)
AZURE_OPENAI_API_KEY=

# ── Content APIs ──────────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key
GNEWS_API_KEY=your-gnews-key
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
